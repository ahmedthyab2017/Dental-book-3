# Railway — Environment Variables (API service)
# Add in: Railway Dashboard → API service → Variables

SPRING_PROFILES_ACTIVE=prod
JWT_SECRET=change-me-to-a-long-random-secret-at-least-32-characters

# After deploying frontend on Vercel, set your production URL:
FRONTEND_URL=https://YOUR-APP.vercel.app

# PostgreSQL — auto-injected when you add Postgres plugin and link to API:
# PGHOST, PGPORT, PGUSER, PGPASSWORD, PGDATABASE
